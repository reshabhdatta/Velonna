    "custom_liquid_AHGKtF": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n@media (max-width: 749px) {\n  .mobile-slider {\n    display: flex !important;\n    flex-wrap: nowrap !important;\n    overflow-x: auto;\n    scroll-snap-type: x mandatory;\n    -webkit-overflow-scrolling: touch;\n    justify-content: flex-start !important;\n    padding-bottom: 10px;\n  }\n\n  .mobile-slider > div {\n    flex: 0 0 85% !important;\n    scroll-snap-align: start;\n  }\n\n  .mobile-slider::-webkit-scrollbar {\n    display: none;\n  }\n}\n</style>\n\n<div style=\"max-width:1200px; margin:40px auto; padding:0 15px;\">\n\n  <div class=\"mobile-slider\" style=\"display:flex; gap:30px; justify-content:center; flex-wrap:wrap; text-align:center;\">\n\n    <!-- Gold -->\n    <div style=\"flex:1 1 30%; min-width:250px;\">\n      <a href=\"https://velonnajewellers.myshopify.com/pages/gold\" style=\"text-decoration:none; color:inherit;\">\n        <img \n          src=\"https://cdn.shopify.com/s/files/1/0811/2603/1578/files/corner_gold.png?v=1773143964\"\n          alt=\"Gold\"\n          style=\"width:100%; height:auto; display:block;\"\n        >\n        <h3 style=\"margin-top:15px;\">Gold</h3>\n      </a>\n    </div>\n\n    <!-- Silver -->\n    <div style=\"flex:1 1 30%; min-width:250px;\">\n      <a href=\"https://velonnajewellers.myshopify.com/pages/silver\" style=\"text-decoration:none; color:inherit;\">\n        <img \n          src=\"https://cdn.shopify.com/s/files/1/0811/2603/1578/files/corner_silver.png?v=1773144078\"\n          alt=\"Silver\"\n          style=\"width:100%; height:auto; display:block;\"\n        >\n        <h3 style=\"margin-top:15px;\">Silver</h3>\n      </a>\n    </div>\n\n    <!-- Lab Grown -->\n    <div style=\"flex:1 1 30%; min-width:250px;\">\n      <a href=\"https://velonnajewellers.myshopify.com/pages/lab-grown\" style=\"text-decoration:none; color:inherit;\">\n        <img \n          src=\"https://cdn.shopify.com/s/files/1/0811/2603/1578/files/corner_lab_grown.png?v=1773144168\"\n          alt=\"Lab Grown\"\n          style=\"width:100%; height:auto; display:block;\"\n        >\n        <h3 style=\"margin-top:15px;\">Lab Grown</h3>\n      </a>\n    </div>\n\n  </div>\n\n</div>",
