        "custom_liquid": "<style>\n.shop-bond-section {\n  text-align: center;\n  margin: 0px 0;\n}\n\n.shop-bond-title {\n  font-size: 32px;\n  margin-bottom: 20px;\n}\n\n.shop-bond-grid {\n  display: flex;\n  justify-content: center;\n  gap: 30px;\n  flex-wrap: wrap;\n}\n\n.bond-card {\n  width: 180px;\n  text-decoration: none;\n  color: #000;\n}\n\n.bond-card img {\n  width: 100%;\n  border-radius: 20px;\n  display: block;\n}\n\n.bond-label {\n  margin-top: 12px;\n  font-size: 20px;\n}\n</style>\n\n<div class=\"shop-bond-section\">\n  <h2 class=\"shop-bond-title\">Shop by Bond</h2>\n\n  <div class=\"shop-bond-grid\">\n\n    <a href=\"/collections/wife\" class=\"bond-card\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0811/2603/1578/files/Wife.png?v=1773307951.png?v=1773226726\">\n      <div class=\"bond-label\"></div>\n    </a>\n\n    <a href=\"/collections/husband\" class=\"bond-card\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0811/2603/1578/files/Husband.png?v=1773308169.png?v=1773226728\">\n      <div class=\"bond-label\"></div>\n    </a>\n\n    <a href=\"/collections/mother\" class=\"bond-card\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0811/2603/1578/files/Mother.png?v=1773310326\">\n      <div class=\"bond-label\"></div>\n    </a>\n\n    <a href=\"/collections/brothers\" class=\"bond-card\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0811/2603/1578/files/Brothers.png?v=1773310516\">\n      <div class=\"bond-label\"></div>\n    </a>\n\n    <a href=\"/collections/sister\" class=\"bond-card\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0811/2603/1578/files/Sister.png?v=1773310918\">\n      <div class=\"bond-label\"></div>\n    </a>\n\n    <a href=\"/collections/friends\" class=\"bond-card\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0811/2603/1578/files/Friends.png?v=1773311163\">\n      <div class=\"bond-label\"></div>\n    </a>\n\n  </div>\n</div>",
