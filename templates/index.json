      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<div class=\"price-section\">\n\n  <h2 class=\"price-heading\">Luxury within Reach</h2>\n\n  <div class=\"price-grid\">\n\n    <!-- 1299 -->\n    <a href=\"https://velonnajewellers.myshopify.com/collections/1299\" class=\"price-card\">\n      <picture>\n\n        <!-- Mobile -->\n        <source media=\"(max-width:768px)\" \n        srcset=\"https://cdn.shopify.com/s/files/1/0811/2603/1578/files/1299_2_74873d3d-b85d-48fb-9446-3aaaf15d2b09.png?v=1773292849\">\n\n        <!-- Desktop -->\n        <img \n        src=\"https://cdn.shopify.com/s/files/1/0811/2603/1578/files/1299_1_92fdcb5b-e6bb-4abd-9d7c-33d9dcf5ba0d.png?v=1773224630\"\n        alt=\"Under 1299\">\n\n      </picture>\n    </a>\n\n    <!-- 1499 -->\n    <a href=\"https://velonnajewellers.myshopify.com/collections/1499\" class=\"price-card\">\n      <picture>\n\n        <!-- Mobile -->\n        <source media=\"(max-width:768px)\" \n        srcset=\"https://cdn.shopify.com/s/files/1/0811/2603/1578/files/1499_1_5d554c75-c70f-4e97-8ead-d24084a16e56.png?v=1773292845\">\n\n        <!-- Desktop -->\n        <img \n        src=\"https://cdn.shopify.com/s/files/1/0811/2603/1578/files/1499_1_8bf9d314-5de0-4e9b-b5ff-2bec89870d72.png?v=1773224627\"\n        alt=\"Under 1499\">\n\n      </picture>\n    </a>\n\n    <!-- 1999 -->\n    <a href=\"https://velonnajewellers.myshopify.com/collections/1999\" class=\"price-card\">\n      <picture>\n\n        <!-- Mobile -->\n        <source media=\"(max-width:768px)\" \n        srcset=\"https://cdn.shopify.com/s/files/1/0811/2603/1578/files/1999_2_842bfb2e-e41e-4809-9ecb-4f3bf1efd3af.png?v=1773292843\">\n\n        <!-- Desktop -->\n        <img \n        src=\"https://cdn.shopify.com/s/files/1/0811/2603/1578/files/1999_1_51f02455-aed0-4977-9822-e253fc01f0fa.png?v=1773224623\"\n        alt=\"Under 1999\">\n\n      </picture>\n    </a>\n\n  </div>\n\n</div>\n\n<style>\n.price-section {\n  text-align: center;\n  margin: px \n}\n\n.price-heading {\n  font-size: 32px;\n  margin-bottom: 20px;\n}\n\n.price-grid {\n  display: flex;\n  justify-content: center;\n  gap: 40px;\n  flex-wrap: wrap;\n}\n\n.price-card {\n  display: block;\n  width: 350px;\n  transition: transform 0.3s ease;\n}\n\n.price-card img {\n  width: 100%;\n  height: auto;\n  display: block;\n  border-radius: 40px;\n}\n\n.price-card:hover {\n  transform: translateY(-8px);\n}\n\n/* MOBILE FIXED ROW */\n@media (max-width:768px){\n\n.price-grid{\n  gap:10px;\n  flex-wrap:nowrap;\n  padding:0 10px; /* left & right spacing added */\n}\n\n.price-card{\n  width:33.33%;\n}\n\n.price-card img{\n  border-radius:25px;\n}\n\n}\n</style>",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 0
      }
