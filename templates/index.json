    "custom_liquid_86744g": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<div class=\"feature-bar-wrapper\">\n  <div class=\"feature-bar-full\">\n    <div class=\"feature-row\">\n\n      <div class=\"feature-item\">925 Fine Silver</div>\n      <div class=\"feature-item\">6 - Month Warranty</div>\n      <div class=\"feature-item\">BIS Hallmark</div>\n      <div class=\"feature-item\">Lifetime Plating</div>\n      <div class=\"feature-item\">Easy 15 Days Return</div>\n\n      <!-- duplicate items only for mobile slider -->\n      <div class=\"feature-item mobile-only\">925 Fine Silver</div>\n      <div class=\"feature-item mobile-only\">6 - Month Warranty</div>\n      <div class=\"feature-item mobile-only\">BIS Hallmark</div>\n      <div class=\"feature-item mobile-only\">Lifetime Plating</div>\n      <div class=\"feature-item mobile-only\">Easy 15 Days Return</div>\n\n    </div>\n  </div>\n</div>\n\n<style>\n\n.feature-bar-wrapper {\n  width: 100vw;\n  margin-left: 50%;\n  transform: translateX(-50%);\n  overflow: hidden;\n}\n\n.feature-bar-full {\n  background: linear-gradient(90deg, #e6c3cf, #d89bb3);\n  padding: 10px 0;\n}\n\n.feature-row {\n  display: flex;\n  justify-content: center;\n  gap: 20px;\n  flex-wrap: nowrap;\n}\n\n.feature-item {\n  background: #f3f3f3;\n  padding: 4px 12px;\n  border-radius: 14px;\n  font-weight: 400;\n  color: #333;\n  white-space: nowrap;\n  font-size: 16px;\n}\n\n/* hide duplicate items on desktop */\n.mobile-only{\n  display:none;\n}\n\n/* mobile slider */\n@media (max-width:768px){\n\n.feature-row{\n  justify-content:flex-start;\n  width:max-content;\n  animation:featureSlide 15s linear infinite;\n}\n\n.mobile-only{\n  display:block;\n}\n\n.feature-item{\n  font-size:12px;\n  padding:3px 8px;\n}\n\n@keyframes featureSlide{\n  0%{transform:translateX(0);}\n  100%{transform:translateX(-50%);}\n}\n\n}\n\n</style>",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "custom_liquid_8dyqaH": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<div class=\"recipient-section\">\n\n  <!-- HIS -->\n  <a href=\"https://velonnajewellers.myshopify.com/collections/his\" class=\"recipient-card\">\n\n    <!-- Desktop Image -->\n    <img class=\"desktop-img\"\n    src=\"https://cdn.shopify.com/s/files/1/0811/2603/1578/files/His.png?v=1773146205\"\n    alt=\"Shop for Him\">\n\n    <!-- Mobile Image -->\n    <img class=\"mobile-img\"\n    src=\"https://cdn.shopify.com/s/files/1/0811/2603/1578/files/Him_New.png?v=1773306936\"\n    alt=\"Shop for Him\">\n\n  </a>\n\n\n  <!-- HER -->\n  <a href=\"https://velonnajewellers.myshopify.com/collections/her\" class=\"recipient-card\">\n\n    <!-- Desktop Image -->\n    <img class=\"desktop-img\"\n    src=\"https://cdn.shopify.com/s/files/1/0811/2603/1578/files/Her.png?v=1773145203\"\n    alt=\"Shop for Her\">\n\n    <!-- Mobile Image -->\n    <img class=\"mobile-img\"\n    src=\"https://cdn.shopify.com/s/files/1/0811/2603/1578/files/Her_New.png?v=1773306936\"\n    alt=\"Shop for Her\">\n\n  </a>\n\n</div>\n\n<style>\n\n.recipient-section{\n  display:flex;\n  gap:20px;\n  justify-content:center;\n  align-items:center;\n  margin:10px auto;\n  max-width:1200px;\n}\n\n.recipient-card{\n  display:block;\n  width:100%;\n}\n\n.recipient-card img{\n  width:100%;\n  height:auto;\n  border-radius:20px;\n}\n\n/* hide mobile images on desktop */\n.mobile-img{\n  display:none;\n}\n\n/* MOBILE */\n@media(max-width:768px){\n\n.recipient-section{\n  display:flex;\n  flex-direction:row;\n  gap:10px;\n  padding:0 10px;\n}\n\n.recipient-card{\n  width:50%;\n}\n\n/* hide desktop image */\n.desktop-img{\n  display:none;\n}\n\n/* show mobile image */\n.mobile-img{\n  display:block;\n}\n\n}\n\n</style>",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
