    "custom_liquid_MThpMB": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<!-- Swiper CSS -->\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css\"/>\n\n<div class=\"swiper mySwiper\">\n  <div class=\"swiper-wrapper\">\n\n    <div class=\"swiper-slide\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0811/2603/1578/files/Untitled_design_13.png?v=1773318359\" />\n    </div>\n\n    <div class=\"swiper-slide\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0811/2603/1578/files/Untitled_design_12.png?v=1773301134.jpg?v=1772274026\" />\n    </div>\n\n    <div class=\"swiper-slide\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0811/2603/1578/files/Explore_All_Hero_web_jpg_1_04fea7fe-8764-4ca8-acc4-621f59fad67a.jpg?v=1772274026\" />\n    </div>\n\n    <div class=\"swiper-slide\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0811/2603/1578/files/Pearl_Banner_Hero_Web.jpg_1_67a601d2-f733-41b8-b8b3-d15db98adf04.jpg?v=1772273957\" />\n    </div>\n\n  </div>\n\n  <!-- Arrows -->\n  <div class=\"swiper-button-next\"></div>\n  <div class=\"swiper-button-prev\"></div>\n</div>\n\n<style>\n.mySwiper {\n  width: 100vw;\n  margin-left: calc(-50vw + 50%);\n}\n\n.swiper-slide img {\n  width: 100%;\n  height: auto;\n  display: block;\n}\n</style>\n\n<!-- Swiper JS -->\n<script src=\"https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js\"></script>\n\n<script>\nvar swiper = new Swiper(\".mySwiper\", {\n  loop: true,\n  autoplay: {\n    delay: 3500,\n    disableOnInteraction: false,\n  },\n  speed: 800,\n  navigation: {\n    nextEl: \".swiper-button-next\",\n    prevEl: \".swiper-button-prev\",\n  },\n  grabCursor: true, // shows grab cursor on desktop\n});\n</script>",
