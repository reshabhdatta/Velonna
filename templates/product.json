 body: JSON.stringify({\n        id: variantId,\n        quantity: 1\n      })\n    })\n    .then(response => response.json())\n    .then(data => {\n      alert(\"Added to cart!\");\n    });\n  }\n\n  function buyNow(variantId) {\n    \/\/ Redirect directly to checkout with product\n    window.location.href = `\/cart\/${variantId}:1?checkout`;\n  }\n<\/script>"}},"custom_liquid_4MYW7d":{"type":"custom_liquid","settings":{"custom_liquid":"<div class=\"ofr-wrap\">\n\n  <!-- Header -->\n  <div class=\"ofr-header\">\n    <span class=\"ofr-title\">Offers For You<\/span>\n    <span class=\"ofr-sub\">(Can be applied at checkout)<\/span>\n  <\/div>\n\n  <!-- Offers -->\n  <div id=\"ofr-list\">\n\n    <!-- Offer 1 -->\n    <div class=\"ofr-card\">\n      <div class=\"ofr-top\" onclick=\"toggleCard(this)\">\n        <div class=\"ofr-left\">\n          <svg viewBox=\"0 0 24 24\" class=\"ofr-icon\">\n            <path d=\"M3 12l7-7h7l4 4v7l-7 7H7z\"\/>\n            <circle cx=\"15\" cy=\"9\" r=\"1\"\/>\n          <\/svg>\n          <span>EXTRA 15% OFF on Silver Jewellery orders above ₹2999<\/span>\n        <\/div>\n        <div class=\"ofr-arrow\">⌄<\/div>\n      <\/div>\n      <div class=\"ofr-bottom\">\n        <span class=\"ofr-code\">VELONNA15<\/span>\n        <span class=\"ofr-copy\" onclick=\"copyCode(event,'VELONNA15')\">Copy Code<\/span>\n      <\/div>\n    <\/div>\n\n    <!-- Offer 2 -->\n    <div class=\"ofr-card\">\n      <div class=\"ofr-top\" onclick=\"toggleCard(this)\">\n        <div class=\"ofr-left\">\n          <svg viewBox=\"0 0 24 24\" class=\"ofr-icon\">\n            <path d=\"M3 12l7-7h7l4 4v7l-7 7H7z\"\/>\n            <circle cx=\"15\" cy=\"9\" r=\"1\"\/>\n          <\/svg>\n          <span>FLAT 5% OFF on Silver Jewellery orders above ₹499<\/span>\n        <\/div>\n        <div class=\"ofr-arrow\">⌄<\/div>\n      <\/div>\n      <div class=\"ofr-bottom\">\n        <span class=\"ofr-code\">VELONNA5<\/span>\n        <span class=\"ofr-copy\" onclick=\"copyCode(event,'VELONNA5')\">Copy Code<\/span>\n      <\/div>\n    <\/div>\n\n    <!-- Hidden Offers -->\n    <div class=\"ofr-more\">\n\n      <div class=\"ofr-card\">\n        <div class=\"ofr-top\" onclick=\"toggleCard(this)\">\n          <div class=\"ofr-left\">\n            <svg viewBox=\"0 0 24 24\" class=\"ofr-icon\">\n              <path d=\"M3 12l7-7h7l4 4v7l-7 7H7z\"\/>\n              <circle cx=\"15\" cy=\"9\" r=\"1\"\/>\n            <\/svg>\n            <span>EXTRA 10% OFF on Silver Jewellery orders above ₹1799<\/span>\n          <\/div>\n          <div class=\"ofr-arrow\">⌄<\/div>\n        <\/div>\n        <div class=\"ofr-bottom\">\n          <span class=\"ofr-code\">VELONNA10<\/span>\n          <span class=\"ofr-copy\" onclick=\"copyCode(event,'VELONNA10')\">Copy Code<\/span>\n        <\/div>\n      <\/div>\n\n      <div class=\"ofr-card\">\n        <div class=\"ofr-top\" onclick=\"toggleCard(this)\">\n          <div class=\"ofr-left\">\n            <svg viewBox=\"0 0 24 24\" class=\"ofr-icon\">\n              <path d=\"M3 12l7-7h7l4 4v7l-7 7H7z\"\/>\n              <circle cx=\"15\" cy=\"9\" r=\"1\"\/>\n            <\/svg>\n            <span>GET FREE Silver Jewellery worth ₹1899 on orders above ₹2499<\/span>\n          <\/div>\n          <div class=\"ofr-arrow\">⌄<\/div>\n        <\/div>\n        <div class=\"ofr-bottom\">\n          <span class=\"ofr-code\">FREE-GIFTNEW<\/span>\n          <span class=\"ofr-copy\" onclick=\"copyCode(event,'FREE-GIFTNEW')\">Copy Code<\/span>\n        <\/div>\n      <\/div>\n\n      <div class=\"ofr-card\">\n        <div class=\"ofr-top\" onclick=\"toggleCard(this)\">\n          <div class=\"ofr-left\">\n            <svg viewBox=\"0 0 24 24\" class=\"ofr-icon\">\n              <path d=\"M3 12l7-7h7l4 4v7l-7 7H7z\"\/>\n              <circle cx=\"15\" cy=\"9\" r=\"1\"\/>\n            <\/svg>\n            <span>FLAT 15% OFF on your first order above ₹999 on Silver Jewellery<\/span>\n          <\/div>\n          <div class=\"ofr-arrow\">⌄<\/div>\n        <\/div>\n        <div class=\"ofr-bottom\">\n          <span class=\"ofr-code\">NEW15<\/span>\n          <span class=\"ofr-copy\" onclick=\"copyCode(event,'NEW15')\">Copy Code<\/span>\n        <\/div>\n      <\/div>\n\n      <div class=\"ofr-card\">\n        <div class=\"ofr-top\" onclick=\"toggleCard(this)\">\n          <div class=\"ofr-left\">\n            <svg viewBox=\"0 0 24 24\" class=\"ofr-icon\">\n              <path d=\"M3 12l7-7h7l4 4v7l-7 7H7z\"\/>\n              <circle cx=\"15\" cy=\"9\" r=\"1\"\/>\n            <\/svg>\n            <span>FLAT 20% OFF on Silver Jewellery orders above ₹4499<\/span>\n          <\/div>\n          <div class=\"ofr-arrow\">⌄<\/div>\n        <\/div>\n        <div class=\"ofr-bottom\">\n          <span class=\"ofr-code\">VELONNA20<\/span>\n          <span class=\"ofr-copy\" onclick=\"copyCode(event,'VELONNA20')\">Copy Code<\/span>\n        <\/div>\n      <\/div>\n\n    <\/div>\n\n  <\/div>\n\n  <!-- Toggle -->\n  <div id=\"ofr-toggle\" onclick=\"toggleOffers()\">+4 more offers<\/div>\n  <div id=\"ofr-close\" onclick=\"toggleOffers()\">Close<\/div>\n\n  <!-- Toast -->\n  <div id=\"ofr-toast\">Copied!<\/div>\n\n<\/div>\n\n<style>\n.ofr-wrap {\n  background: #f5f5f5;\n  padding: 16px;\n  border-radius: 16px;\n  font-family: Inter, sans-serif;\n}\n\n.ofr-header {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  margin-bottom: 12px;\n}\n\n.ofr-title {\n  font-weight: 700;\n  font-size: 20px;\n}\n\n.ofr-sub {\n  color: #666;\n  font-size: 14px;\n}\n\n.ofr-card {\n  background: #f0f0f0;\n  border-radius: 16px;\n  padding: 14px;\n  margin-bottom: 12px;\n}\n\n.ofr-top {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  cursor: pointer;\n}\n\n.ofr-left {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  color: #333;\n  font-weight: 500;\n}\n\n.ofr-icon {\n  width: 28px;\n  height: 28px;\n  stroke: #222;\n  stroke-width: 1.5;\n  fill: none;\n}\n\n.ofr-arrow {\n  color: #666;\n}\n\n.ofr-bottom {\n  display: none;\n  justify-content: space-between;\n  align-items: center;\n  margin-top: 10px;\n}\n\n.ofr-card.active .ofr-bottom {\n  display: flex;\n}\n\n.ofr-code {\n  border: 1px solid #8b2c2c;\n  color: #8b2c2c;\n  padding: 6px 10px;\n  font-weight: 600;\n}\n\n.ofr-copy {\n  color: #1a73e8;\n  font-weight: 500;\n  cursor: pointer;\n}\n\n#ofr-toggle,\n#ofr-close {\n  text-align: center;\n  margin-top: 10px;\n  text-decoration: underline;\n  cursor: pointer;\n}\n\n#ofr-close {\n  display: none;\n}\n\n.ofr-more {\n  display: none;\n}\n\n\/* TOAST FIXED *\/\n#ofr-toast {\n  position: fixed !important;\n  bottom: 30px !important;\n  left: 50% !important;\n  transform: translateX(-50%) !important;\n  background: #333 !important;\n  color: #fff !important;\n  padding: 10px 16px !important;\n  border-radius: 8px !important;\n  font-size: 14px !important;\n  opacity: 0;\n  visibility: hidden;\n  transition: opacity 0.3s ease;\n  z-index: 999999 !important;\n}\n\n#ofr-toast.show {\n  opacity: 1 !important;\n  visibility: visible !important;\n}\n<\/style>\n\n<script>\nfunction toggleCard(el) {\n  const card = el.parentElement;\n  const arrow = el.querySelector('.ofr-arrow');\n\n  card.classList.toggle('active');\n\n  arrow.textContent = card.classList.contains('active') ? '⌃' : '⌄';\n}\n\nfunction toggleOffers() {\n  const more = document.querySelector('.ofr-more');\n  const toggle = document.getElementById('ofr-toggle');\n  const close = document.getElementById('ofr-close');\n\n  if (more.style.display === 'block') {\n    more.style.display = 'none';\n    toggle.style.display = 'block';\n    close.style.display = 'none';\n  } else {\n    more.style.display = 'block';\n    toggle.style.display = 'none';\n    close.style.display = 'block';\n  }\n}\n\nfunction copyCode(e, code) {\n  e.stopPropagation();\n\n  const temp = document.createElement(\"textarea\");\n  temp.value = code;\n  document.body.appendChild(temp);\n  temp.select();\n  document.execCommand(\"copy\");\n  document.body.removeChild(temp);\n\n  const toast = document.getElementById('ofr-toast');\n\n  toast.classList.remove('show');\n  void toast.offsetWidth; \/\/ force reflow\n\n  toast.classList.add('show');\n\n  setTimeout(() => {\n    toast.classList.remove('show');\n  }, 1500);\n}\n<\/script>"}},"quantity-selector":{"type":"quantity_selector","disabled":true,"settings":{}},"buy_buttons":{"type":"buy_buttons","disabled":true,"settings":{"show_dynamic_checkout":true,"show_gift_card_recipient":true}},"description":{"type":"description","settings":{}}},"block_order":["vendor","title","variant-picker","price","custom_liquid_DaDDUX","custom_liquid_7y7Xzj","custom_liquid_4MYW7d","quantity-selector","buy_buttons","description"],"settings":{"enable_sticky_info":true,"color_scheme":"scheme-1","media_size":"medium","constrain_to_viewport":true,"media_fit":"contain","gallery_layout":"thumbnail_slider","mobile_thumbnails":"show","media_position":"left","image_zoom":"lightbox","hide_variants":true,"enable_video_looping":false,"padding_top":36,"padding_bottom":36}},"collapsible-content":{"type":"collapsible-content","blocks":{"collapsible-row-0":{"type":"collapsible_row","settings":{"heading":"How can I track the status of my order?","icon":"none","row_content":"<p>We usually process and ship all orders within 2-3 business days of receiving them. Once your order is shipped, you will receive notifications via SMS, email, and WhatsApp with details of the delivery partner and your tracking ID. We are committed to providing a smooth and timely delivery experience and are here to assist with any inquiries you may have regarding your order’s status.<\/p>","page":""}},"collapsible-row-1":{"type":"collapsible_row","settings":{"heading":"I didn't like the product. How can I return my order?","icon":"none","row_content":"<p>You can place a return request through our website.<\/p><p><strong>Website:<\/strong><br\/><br\/>Log in using your registered email ID → Go to <strong>My Orders<\/strong> → Select the order → Click <strong>Return<\/strong> → Choose the item(s) and select the reason → Submit.<\/p><p>Return pickup may take up to <strong>3 working days<\/strong>.<\/p><p>If the pickup is delayed, please contact <strong>Velonna Customer Support<\/strong> at ********16 (10 AM–6:30 PM) or raise a support ticket through our website.<\/p>","page":""}},"collapsible-row-2":{"type":"collapsible_row","settings":{"heading":"How much time does it take to deliver the order?","icon":"none","row_content":"<p>It may take up to 48 hours for us to process your order after confirmation. Once your order is shipped, most deliveries are completed within 4 to 6 business days, depending on your location. You will receive SMS, email, and WhatsApp notifications once the order is shipped.<\/p>","page":""}},"collapsible_row_9GXcbf":{"type":"collapsible_row","settings":{"heading":"What is your No Questions Asked return policy?","icon":"none","row_content":"<p>We understand that shopping online can sometimes be tricky, and we want you to truly love your purchase! That’s why <strong>Velonna offers a hassle-free 15-day return policy<\/strong> on all unused and unworn items—no questions asked.<\/p><p>Please note that <strong>Made-to-Order Gold jewellery, personalised jewellery, rakhis, perfumes, candles, coins, and God idols<\/strong> are not eligible for returns.<\/p><p>All items must be returned in their <strong>original packaging<\/strong> and in <strong>unused condition<\/strong>. Additionally, any <strong>FREE gift<\/strong> received with the order must also be returned if the order value falls below ₹2199 after the return.<\/p><p>Refunds will be processed after a thorough quality check of the returned items, in accordance with Velonna’s return policy.<\/p>","page":""}}},"block_order":["collapsible-row-0","collapsible-row-1","collapsible-row-2","collapsible_row_9GXcbf"],"settings":{"caption":"","heading":"FAQs","heading_size":"h1","heading_alignmen