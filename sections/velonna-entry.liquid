{% comment %} Velonna Entry Overlay {% endcomment %}

<div class="vel-entry" id="vel-entry" aria-modal="true" role="dialog">
  <div class="vel-entry__header">
    <p class="vel-entry__eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="vel-entry__headline">{{ section.settings.headline | newline_to_br }}</h2>
  </div>
  <div class="vel-entry__panels">
    <a href="{{ section.settings.silver_url | default: '/collections/silver' }}" class="vel-entry__panel vel-entry__panel--silver">
      <div class="vel-entry__panel-bg"></div>
      <div class="vel-entry__panel-content">
        <span class="vel-entry__panel-category">{{ section.settings.silver_label }}</span>
        <span class="vel-entry__panel-line"></span>
        <span class="vel-entry__panel-sub">{{ section.settings.silver_sub }}</span>
        <span class="vel-entry__panel-cta">{{ section.settings.silver_cta }} &rarr;</span>
      </div>
    </a>
    <a href="{{ section.settings.diamond_url | default: '/collections/diamonds' }}" class="vel-entry__panel vel-entry__panel--diamond">
      <div class="vel-entry__panel-bg"></div>
      <div class="vel-entry__panel-content">
        <span class="vel-entry__panel-category">{{ section.settings.diamond_label }}</span>
        <span class="vel-entry__panel-line"></span>
        <span class="vel-entry__panel-sub">{{ section.settings.diamond_sub }}</span>
        <span class="vel-entry__panel-cta">{{ section.settings.diamond_cta }} &rarr;</span>
      </div>
    </a>
    <a href="{{ section.settings.both_url | default: '/collections/all' }}" class="vel-entry__panel vel-entry__panel--both">
      <div class="vel-entry__panel-bg"></div>
      <div class="vel-entry__panel-content">
        <span class="vel-entry__panel-category">{{ section.settings.both_label }}</span>
        <span class="vel-entry__panel-line"></span>
        <span class="vel-entry__panel-sub">{{ section.settings.both_sub }}</span>
        <span class="vel-entry__panel-cta">{{ section.settings.both_cta }} &rarr;</span>
      </div>
    </a>
  </div>
  <button class="vel-entry__skip" id="vel-entry-skip" type="button">
    {{ section.settings.skip_label }}
    <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 3v10M3 9l5 5 5-5" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </button>
</div>

<style>
  .vel-entry{position:fixed;inset:0;z-index:9990;display:flex;flex-direction:column;background:#0a0a0a;transition:opacity .7s cubic-bezier(.4,0,.2,1),visibility .7s;overflow:hidden}
  .vel-entry.is-hidden{opacity:0;visibility:hidden;pointer-events:none}

  /* Header — absolute on desktop only */
  .vel-entry__header{position:absolute;top:0;left:0;right:0;text-align:center;padding:3rem 2rem 1rem;z-index:10;pointer-events:none;opacity:0;animation:vel-fade-in .6s ease .05s forwards}
  .vel-entry__eyebrow{font-family:'Neue Haas Grotesk','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:.65rem;letter-spacing:.25em;text-transform:uppercase;color:rgba(255,255,255,.35);margin:0 0 1rem}
  .vel-entry__headline{font-family:'Cormorant Garamond','Cormorant',Georgia,serif;font-size:clamp(2rem,4vw,3.25rem);font-weight:300;font-style:italic;line-height:1.2;color:rgba(255,255,255,.88);margin:0}

  /* Panels */
  .vel-entry__panels{display:flex;width:100%;height:100%;overflow:hidden}
  .vel-entry__panel{flex:1;position:relative;display:flex;align-items:flex-end;justify-content:flex-start;padding:3.5rem 3rem;text-decoration:none;overflow:hidden;transition:flex .55s cubic-bezier(.4,0,.2,1);opacity:0;transform:translateY(30px);animation:vel-panel-in .8s cubic-bezier(.4,0,.2,1) forwards}
  .vel-entry__panel:nth-child(1){animation-delay:.1s}
  .vel-entry__panel:nth-child(2){animation-delay:.2s}
  .vel-entry__panel:nth-child(3){animation-delay:.3s}
  .vel-entry__panels:hover .vel-entry__panel{flex:.7}
  .vel-entry__panels:hover .vel-entry__panel:hover{flex:1.6}

  .vel-entry__panel-bg{position:absolute;inset:0;transition:opacity .55s ease}
  .vel-entry__panel--silver .vel-entry__panel-bg{background:linear-gradient(160deg,#141414,#1e1e1e)}
  .vel-entry__panel--diamond .vel-entry__panel-bg{background:linear-gradient(160deg,#100f0c,#1a1710)}
  .vel-entry__panel--both .vel-entry__panel-bg{background:linear-gradient(160deg,#0a0a0a,#111)}
  .vel-entry__panels:hover .vel-entry__panel:not(:hover) .vel-entry__panel-bg{opacity:.45}

  .vel-entry__panel+.vel-entry__panel::before{content:'';position:absolute;left:0;top:20%;bottom:20%;width:1px;background:rgba(255,255,255,.08);z-index:1}

  .vel-entry__panel-content{position:relative;z-index:2;display:flex;flex-direction:column;gap:.75rem}
  .vel-entry__panel-category{font-family:'Cormorant Garamond','Cormorant',Georgia,serif;font-size:clamp(1.75rem,3vw,2.75rem);font-weight:300;line-height:1.15;display:block}
  .vel-entry__panel--silver .vel-entry__panel-category{color:#c8c8c8}
  .vel-entry__panel--diamond .vel-entry__panel-category{color:#ddc98a}
  .vel-entry__panel--both .vel-entry__panel-category{color:rgba(255,255,255,.88)}

  .vel-entry__panel-line{display:block;width:2rem;height:1px;background:currentColor;opacity:.25}
  .vel-entry__panel--silver .vel-entry__panel-line{color:#c8c8c8}
  .vel-entry__panel--diamond .vel-entry__panel-line{color:#ddc98a}
  .vel-entry__panel--both .vel-entry__panel-line{color:rgba(255,255,255,.6)}

  .vel-entry__panel-sub{font-family:'Neue Haas Grotesk','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:.7rem;letter-spacing:.18em;text-transform:uppercase;display:block;transition:opacity .3s ease}
  .vel-entry__panel--silver .vel-entry__panel-sub{color:rgba(200,200,200,.5)}
  .vel-entry__panel--diamond .vel-entry__panel-sub{color:rgba(221,201,138,.5)}
  .vel-entry__panel--both .vel-entry__panel-sub{color:rgba(255,255,255,.35)}
  .vel-entry__panel:hover .vel-entry__panel-sub{opacity:1}

  .vel-entry__panel-cta{font-family:'Neue Haas Grotesk','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;display:block;opacity:0;transform:translateY(6px);transition:opacity .3s ease,transform .3s ease}
  .vel-entry__panel--silver .vel-entry__panel-cta{color:#c8c8c8}
  .vel-entry__panel--diamond .vel-entry__panel-cta{color:#ddc98a}
  .vel-entry__panel--both .vel-entry__panel-cta{color:rgba(255,255,255,.7)}
  .vel-entry__panel:hover .vel-entry__panel-cta{opacity:1;transform:translateY(0)}

  /* Skip */
  .vel-entry__skip{position:absolute;bottom:2.5rem;left:50%;transform:translateX(-50%);background:none;border:none;cursor:pointer;display:flex;align-items:center;gap:.5rem;font-family:'Neue Haas Grotesk','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.25);padding:.5rem 1rem;transition:color .3s ease;z-index:10;white-space:nowrap;opacity:0;animation:vel-fade-in .6s ease .5s forwards}
  .vel-entry__skip:hover{color:rgba(255,255,255,.55)}
  .vel-entry__skip svg{animation:vel-bounce 2s ease-in-out infinite}

  @keyframes vel-panel-in{to{opacity:1;transform:translateY(0)}}
  @keyframes vel-fade-in{to{opacity:1}}
  @keyframes vel-bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(3px)}}

  /* ════════════════════════════
     MOBILE ≤ 680px
     Key change: header becomes a
     FLOW item (not absolute) so
     panels start below it.
  ════════════════════════════ */
  @media(max-width:680px){
    /* Header flows normally — no absolute positioning */
    .vel-entry__header{
      position:relative;
      top:auto;left:auto;right:auto;
      padding:2rem 1.25rem 1rem;
      flex-shrink:0;
      pointer-events:auto;
    }
    .vel-entry__eyebrow{font-size:.6rem;margin-bottom:.6rem}
    .vel-entry__headline{font-size:1.45rem}

    /* Panels fill remaining height */
    .vel-entry__panels{
      flex:1;
      flex-direction:column;
      min-height:0;
    }

    /* Each panel = equal share of remaining vertical space */
    .vel-entry__panel{
      flex:1;
      padding:0 1.25rem 1.1rem;
      align-items:flex-end;
      justify-content:flex-start;
      min-height:0;
      transition:none;
    }

    /* Disable desktop hover-expand on touch */
    .vel-entry__panels:hover .vel-entry__panel,
    .vel-entry__panels:hover .vel-entry__panel:hover{flex:1}

    /* Horizontal dividers between stacked panels */
    .vel-entry__panel+.vel-entry__panel::before{
      left:6%;right:6%;
      top:0;bottom:auto;
      width:auto;height:1px;
    }

    .vel-entry__panel-category{font-size:1.4rem}

    /* Sub always visible on mobile */
    .vel-entry__panel--silver .vel-entry__panel-sub{color:rgba(200,200,200,.65)}
    .vel-entry__panel--diamond .vel-entry__panel-sub{color:rgba(221,201,138,.65)}
    .vel-entry__panel--both .vel-entry__panel-sub{color:rgba(255,255,255,.5)}

    /* CTA always visible on mobile */
    .vel-entry__panel-cta{opacity:1;transform:none}

    /* Skip flows at bottom of the flex column — not absolute */
    .vel-entry__skip{
      position:relative;
      bottom:auto;left:auto;
      transform:none;
      justify-content:center;
      padding:.9rem 1rem 1.4rem;
      flex-shrink:0;
    }
  }
</style>

<script>
(function(){
  var K='vel_entry_seen',o=document.getElementById('vel-entry'),s=document.getElementById('vel-entry-skip');
  if(!o)return;
  if(sessionStorage.getItem(K)){o.classList.add('is-hidden');return;}
  function d(){sessionStorage.setItem(K,'1');o.classList.add('is-hidden');}
  if(s)s.addEventListener('click',d);
  o.querySelectorAll('.vel-entry__panel').forEach(function(p){p.addEventListener('click',function(){sessionStorage.setItem(K,'1');});});
  document.addEventListener('keydown',function(e){if(e.key==='Escape')d();});
})();
</script>

{% schema %}
{"name":"Entry Overlay","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"The Velonna Atelier · Est. 2014"},{"type":"textarea","id":"headline","label":"Headline","default":"How would you like\nto treat yourself\ntoday?"},{"type":"header","content":"Silver"},{"type":"text","id":"silver_label","label":"Label","default":"Silver"},{"type":"text","id":"silver_sub","label":"Subline","default":"For the everyday ritual"},{"type":"text","id":"silver_cta","label":"CTA","default":"Explore"},{"type":"url","id":"silver_url","label":"Link"},{"type":"header","content":"Lab-Grown Diamonds"},{"type":"text","id":"diamond_label","label":"Label","default":"Lab-Grown Diamonds"},{"type":"text","id":"diamond_sub","label":"Subline","default":"Light, held forever"},{"type":"text","id":"diamond_cta","label":"CTA","default":"Explore"},{"type":"url","id":"diamond_url","label":"Link"},{"type":"header","content":"Both"},{"type":"text","id":"both_label","label":"Label","default":"The Full Atelier"},{"type":"text","id":"both_sub","label":"Subline","default":"Show me everything"},{"type":"text","id":"both_cta","label":"CTA","default":"Enter"},{"type":"url","id":"both_url","label":"Link"},{"type":"header","content":"Skip"},{"type":"text","id":"skip_label","label":"Skip label","default":"Enter the atelier"}],"presets":[{"name":"Entry Overlay"}]}
{% endschema %}