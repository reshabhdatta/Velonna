    { "type": "image_picker", "id": "hero_image", "label": "Hero fallback image" },
    { "type": "text",   "id": "hero_tag",     "label": "Hero tag line",  "default": "Mumbai · Est. 2014 · Limited Edition" },
    { "type": "text",   "id": "hero_line1",   "label": "Title line 1",   "default": "An Heirloom" },
    { "type": "text",   "id": "hero_line2",   "label": "Title line 2 (italic)", "default": "In Light" },
    { "type": "text",   "id": "hero_line3",   "label": "Title line 3",   "default": "& Stone" },
    { "type": "text",   "id": "edition_number", "label": "Edition number", "default": "12" },
    { "type": "text",   "id": "edition_label",  "label": "Edition label",  "default": "Numbered Editions" },

    { "type": "header", "content": "Statement" },
    { "type": "text",   "id": "statement_quote",  "label": "Quote",  "default": "Worn today. Worn a century from now." },
    { "type": "text",   "id": "statement_source", "label": "Source", "default": "The Velonna Atelier · 2014" },

    { "type": "header", "content": "Heritage" },
    { "type": "image_picker", "id": "heritage_image",    "label": "Heritage image" },
    { "type": "text",   "id": "heritage_location", "label": "Location tag", "default": "The Atelier · 12 Forbes St, Fort, Mumbai" },
    { "type": "textarea","id": "heritage_title",   "label": "Title (use newlines)", "default": "A Decade\nof Quiet\nMastery" },
    { "type": "textarea","id": "heritage_body1",   "label": "Body paragraph 1", "default": "Founded above a quiet street in Fort, Mumbai, Velonna has held to a single conviction — that a jewel made slowly by hand will outlast every trend surrounding it." },
    { "type": "textarea","id": "heritage_body2",   "label": "Body paragraph 2", "default": "Every piece begins with a stone selected in person, ends with a master jeweller's signature on the inside, and travels with the Book that records both. There are no batches, no seasons. Only twelve." },
    { "type": "text",   "id": "stat1_num",   "label": "Stat 1 number", "default": "412" },
    { "type": "text",   "id": "stat1_label", "label": "Stat 1 label",  "default": "Hours per piece" },
    { "type": "text",   "id": "stat2_num",   "label": "Stat 2 number", "default": "12" },
    { "type": "text",   "id": "stat2_label", "label": "Stat 2 label",  "default": "Numbered pieces" },
    { "type": "text",   "id": "stat3_num",   "label": "Stat 3 number", "default": "100yr" },
    { "type": "text",   "id": "stat3_label", "label": "Stat 3 label",  "default": "Guarantee" },

    { "type": "header", "content": "Editorial section 1" },
    { "type": "text",   "id": "ed1_issue",   "label": "Eyebrow",  "default": "Savoir-faire · The Edition" },
    { "type": "textarea","id": "ed1_title",  "label": "Title",    "default": "The Anatomy\nof Light" },
    { "type": "textarea","id": "ed1_body",   "label": "Body",     "default": "Seventy-five components. Every prong shaped by a human eye, every stone seated without a jig. What you hold is not a product — it is a record of decisions made by a single pair of hands across more than four hundred hours." },
    { "type": "text",   "id": "ed1_cta",     "label": "CTA text", "default": "Book a private viewing" },
    { "type": "image_picker", "id": "ed1_image", "label": "Image" },
    { "type": "text",   "id": "ed1_caption", "label": "Image caption", "default": "Velonna · Botanica · Edition 2026" },

    { "type": "header", "content": "Full-bleed interlude" },
    { "type": "url",    "id": "bleed_video",   "label": "Bleed video URL" },
    { "type": "image_picker", "id": "bleed_image", "label": "Bleed fallback image" },
    { "type": "text",   "id": "bleed_eyebrow", "label": "Eyebrow",  "default": "The Rose Collection · Dawn Solitaire" },
    { "type": "textarea","id": "bleed_quote",  "label": "Quote",    "default": "Not for the world to see. For the one who wears it to feel." },
    { "type": "text",   "id": "bleed_caption", "label": "Caption",  "default": "No. 01 / 12 · Helena Marsh · Mumbai" },

    { "type": "header", "content": "Editorial section 2" },
    { "type": "text",   "id": "ed2_issue",   "label": "Eyebrow",  "default": "The Rose Collection" },
    { "type": "textarea","id": "ed2_title",  "label": "Title",    "default": "Rose\nen Pose" },
    { "type": "textarea","id": "ed2_body",   "label": "Body",     "default": "Pink-pavé sapphire petals. White-diamond thorny vines wrapping the shank twice. Two closed buds on slim rose-gold stems. One ring. One wearer. Signed at the root." },
    { "type": "text",   "id": "ed2_cta",     "label": "CTA text", "default": "Reserve this piece" },
    { "type": "image_picker", "id": "ed2_image", "label": "Image" },
    { "type": "text",   "id": "ed2_caption", "label": "Image caption", "default": "Velonna · Rose en Pose · 2026" },

    { "type": "header", "content": "Reservation form" },
    { "type": "image_picker", "id": "form_image", "label": "Si