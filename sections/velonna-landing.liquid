{
  "name": "Velonna Landing",
  "tag": "div",
  "class": "vl-section",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "url",          "id": "hero_video",    "label": "Hero video URL" },
    { "type": "image_picker", "id": "hero_image",    "label": "Hero image (fallback)" },
    { "type": "text",         "id": "hero_eyebrow",  "label": "Eyebrow", "default": "The Velonna Atelier · Est. 2024" },
    { "type": "textarea",     "id": "hero_title",    "label": "Title (use newlines)", "default": "Contemporary\nLuxury,\nAccessible." },
    { "type": "text",         "id": "hero_sub",      "label": "Subtitle", "default": "Silver, lab-grown stones, and Swarovski crystals. International couture aesthetics at prices that make sense." },
    { "type": "text",         "id": "hero_cta_label","label": "CTA label", "default": "Explore the collections" },
    { "type": "url",          "id": "hero_cta_url",  "label": "CTA URL" },

    { "type": "header", "content": "Collection Tiles" },
    { "type": "image_picker", "id": "tile1_image", "label": "Tile 1 — Silver image" },
    { "type": "image_picker", "id": "tile2_image", "label": "Tile 2 — Created Diamonds image" },
    { "type": "image_picker", "id": "tile3_image", "label": "Tile 3 — All Collections image" },

    { "type": "header", "content": "Statement" },
    { "type": "textarea", "id": "statement_quote", "label": "Quote", "default": "International couture-like designs and jewellery inspired by global brands — both with good materials and accessible price points." },
    { "type": "text",     "id": "statement_attr",  "label": "Attribution", "default": "Arkit Jain, Founder · The Retail Jeweller, March–April 2026" },

    { "type": "header", "content": "Editorial — Silver" },
