{% comment %} VELONNA — Cartier-inspired editorial landing {% endcomment %}

<style>
  .vl *, .vl *::before, .vl *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --vl-ink:    #080808;
    --vl-cream:  #f5f0e8;
    --vl-warm:   #ede8df;
    --vl-gold:   #c8a96e;
    --vl-mist:   rgba(245,240,232,0.55);
    --vl-rule:   rgba(200,169,110,0.18);
    --vl-rule-d: rgba(26,22,18,0.12);
  }

  .vl {
    background: var(--vl-ink);
    color: var(--vl-cream);
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 300;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }
  .vl a { color: inherit; text-decoration: none; }
  .vl img, .vl video { display: block; max-width: 100%; }

  /* ── HERO ─────────────────────────────────────────────── */
  .vl-hero {
    position: relative;
    height: 100svh; min-height: 560px;
    display: flex; align-items: flex-end;
    overflow: hidden;
  }
  .vl-hero-media {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
  }
  .vl-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(8,8,8,0.15) 0%,
      rgba(8,8,8,0.05) 30%,
      rgba(8,8,8,0.60) 75%,
      rgba(8,8,8,0.95) 100%
    );
  }
  .vl-hero-content {
    position: relative; z-index: 2;
    width: 100%; padding: 0 6vw 8vh;
  }
  .vl-hero-eyebrow {
    font-size: 10px; letter-spacing: 0.32em; text-transform: uppercase;
    color: var(--vl-gold); margin-bottom: 1.5rem;
  }
  .vl-hero-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(48px, 8vw, 108px);
    font-weight: 400; line-height: 0.95;
    letter-spacing: -0.01em;
    max-width: 700px;
  }
  .vl-hero-title em { font-style: italic; color: var(--vl-mist); }
  .vl-hero-sub {
    margin-top: 2rem;
    font-size: clamp(12px, 1.2vw, 14px);
    letter-spacing: 0.08em;
    color: rgba(245,240,232,0.5);
    max-width: 320px;
    line-height: 1.7;
  }
  .vl-hero-cta {
    display: inline-flex; align-items: center; gap: 10px;
    margin-top: 2.5rem;
    font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--vl-cream);
    border-bottom: 1px solid rgba(245,240,232,0.3);
    padding-bottom: 4px;
    transition: border-color 0.25s, gap 0.25s;
  }
  .vl-hero-cta::after { content: '→'; }
  .vl-hero-cta:hover { border-color: var(--vl-gold); gap: 18px; }

  /* ── MARQUEE ──────────────────────────────────────────── */
  .vl-band {
    border-top: 1px solid var(--vl-rule);
    border-bottom: 1px solid var(--vl-rule);
    overflow: hidden; white-space: nowrap;
  }
  .vl-band-track {
    display: inline-flex;
    animation: vlMarquee 32s linear infinite;
  }
  .vl-band-group { display: inline-flex; align-items: center; padding: 14px 0; }
  .vl-band-item {
    font-size: 10px; letter-spacing: 0.24em; text-transform: uppercase;
    color: rgba(245,240,232,0.38); padding: 0 28px;
  }
  .vl-band-dot { color: var(--vl-gold); font-size: 14px; line-height: 1; }
  @keyframes vlMarquee { from{transform:translateX(0)} to{transform:translateX(-50%)} }

  /* ── COLLECTION TILES (Cartier-inspired 3-col) ─────────── */
  .vl-tiles {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    background: var(--vl-cream);
  }
  .vl-tile {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3/4;
    cursor: pointer;
  }
  .vl-tile + .vl-tile {
    border-left: 1px solid var(--vl-rule-d);
  }
  .vl-tile-img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .vl-tile:hover .vl-tile-img { transform: scale(1.06); }
  .vl-tile-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 50%,
      rgba(8,8,8,0.65) 100%
    );
  }
  .vl-tile-label {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 2.5rem 2rem 2rem;
    color: #fff;
  }
  .vl-tile-eyebrow {
    font-size: 9px; letter-spacing: 0.28em; text-transform: uppercase;
    color: var(--vl-gold); margin-bottom: 0.4rem;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.35s, transform 0.35s;
  }
  .vl-tile:hover .vl-tile-eyebrow { opacity: 1; transform: translateY(0); }
  .vl-tile-name {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(20px, 2.2vw, 30px);
    font-weight: 400;
    line-height: 1.15;
  }
  .vl-tile-discover {
    display: inline-flex; align-items: center; gap: 8px;
    margin-top: 0.85rem;
    font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    border-bottom: 1px solid rgba(255,255,255,0.2);
    padding-bottom: 3px;
    transition: color 0.25s, border-color 0.25s, gap 0.25s;
  }
  .vl-tile-discover::after { content: '→'; }
  .vl-tile:hover .vl-tile-discover {
    color: var(--vl-gold);
    border-color: var(--vl-gold);
    gap: 14px;
  }
  /* Placeholder when no image */
  .vl-tile-placeholder {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, #111 0%, #1a1714 100%);
    display: flex; align-items: center; justify-content: center;
  }
  .vl-tile-placeholder span {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
    color: rgba(245,240,232,0.12);
  }

  /* ── STATEMENT ────────────────────────────────────────── */
  .vl-statement {
    padding: 10rem 6vw;
    background: var(--vl-ink);
    border-bottom: 1px solid var(--vl-rule);
  }
  .vl-statement-inner {
    max-width: 800px; margin: 0 auto; text-align: center;
  }
  .vl-statement-rule {
    width: 40px; height: 1px;
    background: var(--vl-gold);
    margin: 0 auto 3rem;
  }
  .vl-statement-q {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(24px, 4vw, 52px);
    font-weight: 400; font-style: italic;
    line-height: 1.25; color: var(--vl-cream);
  }
  .vl-statement-attr {
    margin-top: 2rem;
    font-size: 10px; letter-spacing: 0.26em; text-transform: uppercase;
    color: var(--vl-gold);
  }

  /* ── EDITORIAL SPLIT ──────────────────────────────────── */
  .vl-editorial {
    display: grid; grid-template-columns: 1fr 1fr;
    min-height: 80vh;
  }
  .vl-editorial.cream { background: var(--vl-cream); color: #1a1612; }
  .vl-editorial.dark  { background: var(--vl-ink);   color: var(--vl-cream); }
  .vl-editorial.rev   { direction: rtl; }
  .vl-editorial.rev > * { direction: ltr; }

  .vl-editorial-vis {
    position: relative; overflow: hidden;
  }
  .vl-editorial-vis img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 1.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .vl-editorial-vis:hover img { transform: scale(1.04); }

  .vl-editorial-txt {
    padding: 8vw 6vw;
    display: flex; flex-direction: column; justify-content: center;
  }
  .cream .vl-editorial-txt { border-left: 1px solid var(--vl-rule-d); }
  .dark  .vl-editorial-txt { border-left: 1px solid var(--vl-rule);   }
  .rev.cream .vl-editorial-txt { border-left: none; border-right: 1px solid var(--vl-rule-d); }
  .rev.dark  .vl-editorial-txt { border-left: none; border-right: 1px solid var(--vl-rule);   }

  .vl-ed-eyebrow {
    font-size: 10px; letter-spacing: 0.28em; text-transform: uppercase;
    margin-bottom: 2.5rem;
    display: flex; align-items: center; gap: 14px;
  }
  .cream .vl-ed-eyebrow { color: rgba(26,22,18,0.4); }
  .dark  .vl-ed-eyebrow { color: var(--vl-gold); }
  .vl-ed-eyebrow::before {
    content: ''; display: block; flex-shrink: 0;
    width: 28px; height: 1px; background: var(--vl-gold);
  }

  .vl-ed-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(32px, 3.8vw, 52px);
    font-weight: 400; line-height: 1.08;
    margin-bottom: 1.75rem;
  }
  .vl-ed-title em { font-style: italic; }
  .cream .vl-ed-title em { color: #5a4a38; }
  .dark  .vl-ed-title em { color: var(--vl-mist); }

  .vl-ed-body {
    font-size: 14px; line-height: 1.85; max-width: 380px;
    margin-bottom: 3rem;
  }
  .cream .vl-ed-body { color: rgba(26,22,18,0.58); }
  .dark  .vl-ed-body { color: rgba(245,240,232,0.5); }

  .vl-ed-link {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase;
    border-bottom: 1px solid;
    padding-bottom: 4px;
    transition: gap 0.25s;
    align-self: flex-start;
  }
  .vl-ed-link::after { content: '→'; }
  .vl-ed-link:hover { gap: 20px; }
  .cream .vl-ed-link { color: #1a1612; border-color: rgba(26,22,18,0.3); }
  .dark  .vl-ed-link { color: var(--vl-gold); border-color: rgba(200,169,110,0.4); }

  /* ── FULL-BLEED FEATURE ──────────────────────────────── */
  .vl-feature {
    position: relative;
    min-height: 70vh;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  .vl-feature-bg {
    position: absolute; inset: 0;
    width: 100%; height: 100%; object-fit: cover;
  }
  .vl-feature-ov {
    position: absolute; inset: 0;
    background: rgba(8,8,8,0.62);
  }
  .vl-feature-content {
    position: relative; z-index: 1;
    text-align: center; padding: 6rem 6vw;
    max-width: 680px;
  }
  .vl-feature-eyebrow {
    font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--vl-gold); margin-bottom: 2rem;
  }
  .vl-feature-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(28px, 4.5vw, 58px);
    font-weight: 400; font-style: italic;
    line-height: 1.22; color: var(--vl-cream);
  }
  .vl-feature-rule {
    width: 40px; height: 1px;
    background: var(--vl-gold);
    margin: 2.5rem auto;
  }
  .vl-feature-cta {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--vl-cream);
    border-bottom: 1px solid rgba(245,240,232,0.3);
    padding-bottom: 4px;
    transition: border-color 0.25s, gap 0.25s;
  }
  .vl-feature-cta::after { content: '→'; }
  .vl-feature-cta:hover { border-color: var(--vl-gold); gap: 18px; }

  /* ── FEATURED PRODUCTS ────────────────────────────────── */
  .vl-products {
    background: var(--vl-cream);
    padding: 8rem 6vw;
    border-top: 1px solid var(--vl-rule-d);
  }
  .vl-products-header {
    display: flex; align-items: flex-end; justify-content: space-between;
    margin-bottom: 4rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--vl-rule-d);
  }
  .vl-products-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 400; color: #1a1612;
    line-height: 1.1;
  }
  .vl-products-title em { font-style: italic; }
  .vl-products-viewall {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase;
    color: #1a1612;
    border-bottom: 1px solid rgba(26,22,18,0.25);
    padding-bottom: 3px;
    white-space: nowrap;
    transition: gap 0.25s;
  }
  .vl-products-viewall::after { content: '→'; }
  .vl-products-viewall:hover { gap: 18px; }

  .vl-product-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
  }
  .vl-product-card {
    background: #fff;
    cursor: pointer;
  }
  .vl-product-card a { display: block; }
  .vl-product-img-wrap {
    position: relative; overflow: hidden;
    aspect-ratio: 3/4;
    background: #f0ece5;
  }
  .vl-product-img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 1s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .vl-product-card:hover .vl-product-img { transform: scale(1.07); }
  .vl-product-info {
    padding: 1.25rem 1rem 1.5rem;
  }
  .vl-product-collection {
    font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--vl-gold); margin-bottom: 0.35rem;
  }
  .vl-product-name {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 15px; font-weight: 400;
    color: #1a1612; line-height: 1.3;
    margin-bottom: 0.4rem;
  }
  .vl-product-price {
    font-size: 13px; color: rgba(26,22,18,0.55);
  }
  /* Empty product placeholder */
  .vl-product-placeholder {
    background: linear-gradient(135deg, #e8e3db, #ddd8ce);
    display: flex; align-items: center; justify-content: center;
  }
  .vl-product-placeholder span {
    font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(26,22,18,0.2);
  }

  /* ── ENQUIRE STRIP ────────────────────────────────────── */
  .vl-enquire {
    display: grid; grid-template-columns: 1fr 1fr;
    min-height: 70vh;
    background: var(--vl-ink);
    border-top: 1px solid var(--vl-rule);
  }
  .vl-enquire-vis {
    position: relative; overflow: hidden;
    border-right: 1px solid var(--vl-rule);
  }
  .vl-enquire-vis img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 1.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .vl-enquire-vis:hover img { transform: scale(1.04); }
  .vl-enquire-vis-ov {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(8,8,8,0.7) 0%, transparent 60%);
  }
  .vl-enquire-vis-caption {
    position: absolute; bottom: 2.5rem; left: 2.5rem;
  }
  .vl-enquire-vis-caption strong {
    display: block;
    font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--vl-gold); margin-bottom: 0.5rem; font-weight: 400;
  }
  .vl-enquire-vis-caption p {
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic; font-size: 18px;
    color: rgba(245,240,232,0.82); line-height: 1.4;
  }

  .vl-enquire-form {
    padding: 7rem 6vw;
    display: flex; flex-direction: column; justify-content: center;
  }
  .vl-enquire-eyebrow {
    font-size: 10px; letter-spacing: 0.28em; text-transform: uppercase;
    color: var(--vl-gold); margin-bottom: 1rem;
  }
  .vl-enquire-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(30px, 3.2vw, 44px);
    font-weight: 400; line-height: 1.1;
    margin-bottom: 0.8rem;
  }
  .vl-enquire-sub {
    font-size: 13px; line-height: 1.85;
    color: rgba(245,240,232,0.5);
    max-width: 360px; margin-bottom: 3rem;
  }
  .vl-form { display: flex; flex-direction: column; gap: 1.25rem; }
  .vl-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .vl-form-g { display: flex; flex-direction: column; gap: 6px; }
  .vl-form-g label {
    font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase;
    color: rgba(245,240,232,0.35);
  }
  .vl-form-g input,
  .vl-form-g select,
  .vl-form-g textarea {
    background: transparent; border: none;
    border-bottom: 1px solid rgba(245,240,232,0.15);
    padding: 10px 0;
    font-size: 14px; font-family: inherit;
    color: var(--vl-cream);
    width: 100%; outline: none;
    -webkit-appearance: none; border-radius: 0;
    transition: border-color 0.25s;
  }
  .vl-form-g select option { background: #1a1612; }
  .vl-form-g textarea { resize: none; min-height: 64px; }
  .vl-form-g input:focus,
  .vl-form-g select:focus,
  .vl-form-g textarea:focus { border-bottom-color: var(--vl-gold); }
  .vl-form-g input::placeholder,
  .vl-form-g textarea::placeholder { color: rgba(245,240,232,0.2); }
  .vl-submit {
    align-self: flex-start;
    margin-top: 0.5rem;
    background: var(--vl-cream); color: var(--vl-ink);
    padding: 14px 36px;
    font-size: 10px; font-family: inherit;
    letter-spacing: 0.22em; text-transform: uppercase;
    border: 1px solid var(--vl-cream); cursor: pointer;
    transition: background 0.25s, color 0.25s;
  }
  .vl-submit:hover { background: transparent; color: var(--vl-cream); }
  .vl-form-note {
    margin-top: 1rem;
    font-size: 11px; color: rgba(245,240,232,0.25);
    line-height: 1.6;
  }

  /* ── RESPONSIVE ───────────────────────────────────────── */
  @media (max-width: 900px) {
    .vl-tiles { grid-template-columns: 1fr; }
    .vl-tile  { aspect-ratio: 4/3; }
    .vl-tile + .vl-tile { border-left: none; border-top: 1px solid var(--vl-rule-d); }
    .vl-editorial, .vl-enquire { grid-template-columns: 1fr; }
    .vl-editorial-vis, .vl-enquire-vis { min-height: 55vw; border-right: none !important; }
    .vl-editorial-txt { border-left: none !important; border-right: none !important; border-top: 1px solid var(--vl-rule-d); padding: 4rem 6vw; }
    .vl-editorial.rev { direction: ltr; }
    .vl-product-grid { grid-template-columns: repeat(2, 1fr); }
    .vl-products-header { flex-direction: column; align-items: flex-start; gap: 1.5rem; }
    .vl-enquire-form { padding: 4rem 6vw; }
    .vl-form-row { grid-template-columns: 1fr; }
    .vl-enquire-vis-caption { bottom: 1.5rem; left: 1.5rem; }
    .dark .vl-editorial-txt { border-top: 1px solid var(--vl-rule); }
  }
  @media (max-width: 540px) {
    .vl-product-grid { grid-template-columns: 1fr 1fr; gap: 1px; }
    .vl-hero-content { padding: 0 5vw 6vh; }
  }
</style>

<div class="vl">

  {%- comment -%} ── HERO ── {%- endcomment -%}
  <section class="vl-hero">
    {%- if section.settings.hero_video != blank -%}
      <video class="vl-hero-media" src="{{ section.settings.hero_video }}"
        autoplay loop muted playsinline preload="auto" aria-hidden="true"></video>
    {%- elsif section.settings.hero_image != blank -%}
      <img class="vl-hero-media"
        src="{{ section.settings.hero_image | image_url: width: 2000 }}"
        alt="{{ section.settings.hero_image.alt | escape }}"
        loading="eager" fetchpriority="high" />
    {%- else -%}
      <video class="vl-hero-media" src="{{ 'y-drop.mp4' | asset_url }}"
        autoplay loop muted playsinline preload="auto" aria-hidden="true"></video>
    {%- endif -%}
    <div class="vl-hero-overlay"></div>
    <div class="vl-hero-content">
      <p class="vl-hero-eyebrow">{{ section.settings.hero_eyebrow }}</p>
      <h1 class="vl-hero-title">
        {{ section.settings.hero_title | newline_to_br }}
      </h1>
      <p class="vl-hero-sub">{{ section.settings.hero_sub }}</p>
      <a class="vl-hero-cta" href="{{ section.settings.hero_cta_url | default: '/collections/all' }}">{{ section.settings.hero_cta_label }}</a>
    </div>
  </section>

  {%- comment -%} ── MARQUEE ── {%- endcomment -%}
  <div class="vl-band" aria-hidden="true">
    <div class="vl-band-track">
      {%- assign band_items = "Sterling silver · Lab-grown stones · Swarovski crystals · Contemporary luxury · Occasion wear · IGI certified · Created diamonds · Metro-first · Est. 2024" | split: " · " -%}
      {%- for n in (1..2) -%}
      <div class="vl-band-group">
        {%- for item in band_items -%}
          <span class="vl-band-item">{{ item }}</span><span class="vl-band-dot" aria-hidden="true">·</span>
        {%- endfor -%}
      </div>
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} ── COLLECTION TILES (Cartier-style 3-col) ── {%- endcomment -%}
  <div class="vl-tiles">

    <a class="vl-tile" href="/collections/silver">
      {%- if section.settings.tile1_image != blank -%}
        <img class="vl-tile-img"
          src="{{ section.settings.tile1_image | image_url: width: 800 }}"
          alt="Silver collection" loading="lazy" />
      {%- else -%}
        <div class="vl-tile-placeholder"><span>Silver</span></div>
      {%- endif -%}
      <div class="vl-tile-overlay"></div>
      <div class="vl-tile-label">
        <p class="vl-tile-eyebrow">Explore the collection</p>
        <p class="vl-tile-name">Silver</p>
        <span class="vl-tile-discover">Discover</span>
      </div>
    </a>

    <a class="vl-tile" href="/collections/lab-grown-diamonds">
      {%- if section.settings.tile2_image != blank -%}
        <img class="vl-tile-img"
          src="{{ section.settings.tile2_image | image_url: width: 800 }}"
          alt="Created Diamonds collection" loading="lazy" />
      {%- else -%}
        <div class="vl-tile-placeholder"><span>Created Diamonds</span></div>
      {%- endif -%}
      <div class="vl-tile-overlay"></div>
      <div class="vl-tile-label">
        <p class="vl-tile-eyebrow">Explore the collection</p>
        <p class="vl-tile-name">Created<br>Diamonds</p>
        <span class="vl-tile-discover">Discover</span>
      </div>
    </a>

    <a class="vl-tile" href="/collections/all">
      {%- if section.settings.tile3_image != blank -%}
        <img class="vl-tile-img"
          src="{{ section.settings.tile3_image | image_url: width: 800 }}"
          alt="All collections" loading="lazy" />
      {%- else -%}
        <div class="vl-tile-placeholder"><span>All Pieces</span></div>
      {%- endif -%}
      <div class="vl-tile-overlay"></div>
      <div class="vl-tile-label">
        <p class="vl-tile-eyebrow">The full atelier</p>
        <p class="vl-tile-name">All<br>Collections</p>
        <span class="vl-tile-discover">Discover</span>
      </div>
    </a>

  </div>

  {%- comment -%} ── STATEMENT ── {%- endcomment -%}
  <section class="vl-statement">
    <div class="vl-statement-inner">
      <div class="vl-statement-rule"></div>
      <p class="vl-statement-q">"{{ section.settings.statement_quote }}"</p>
      <p class="vl-statement-attr">{{ section.settings.statement_attr }}</p>
    </div>
  </section>

  {%- comment -%} ── EDITORIAL: SILVER (cream section) ── {%- endcomment -%}
  <section class="vl-editorial cream">
    <div class="vl-editorial-vis">
      {%- if section.settings.ed1_image != blank -%}
        <img src="{{ section.settings.ed1_image | image_url: width: 1200 }}"
          alt="{{ section.settings.ed1_image.alt | escape }}" loading="lazy" />
      {%- else -%}
        <div class="vl-tile-placeholder" style="height:100%;"><span>Silver Collection</span></div>
      {%- endif -%}
    </div>
    <div class="vl-editorial-txt">
      <p class="vl-ed-eyebrow">{{ section.settings.ed1_eyebrow }}</p>
      <h2 class="vl-ed-title">{{ section.settings.ed1_title | newline_to_br }}</h2>
      <p class="vl-ed-body">{{ section.settings.ed1_body }}</p>
      <a class="vl-ed-link" href="{{ section.settings.ed1_url | default: '/collections/silver' }}">{{ section.settings.ed1_cta }}</a>
    </div>
  </section>

  {%- comment -%} ── FULL-BLEED FEATURE ── {%- endcomment -%}
  <section class="vl-feature">
    {%- if section.settings.feature_image != blank -%}
      <img class="vl-feature-bg"
        src="{{ section.settings.feature_image | image_url: width: 2000 }}"
        alt="" aria-hidden="true" loading="lazy" />
    {%- else -%}
      <video class="vl-feature-bg" src="{{ 'extra.mp4' | asset_url }}"
        autoplay loop muted playsinline preload="metadata" aria-hidden="true"></video>
    {%- endif -%}
    <div class="vl-feature-ov"></div>
    <div class="vl-feature-content">
      <p class="vl-feature-eyebrow">{{ section.settings.feature_eyebrow }}</p>
      <p class="vl-feature-title">"{{ section.settings.feature_quote }}"</p>
      <div class="vl-feature-rule"></div>
      <a class="vl-feature-cta" href="{{ section.settings.feature_cta_url | default: '/collections/lab-grown-diamonds' }}">{{ section.settings.feature_cta }}</a>
    </div>
  </section>

  {%- comment -%} ── EDITORIAL: CREATED DIAMONDS (dark section, reversed) ── {%- endcomment -%}
  <section class="vl-editorial dark rev">
    <div class="vl-editorial-vis">
      {%- if section.settings.ed2_image != blank -%}
        <img src="{{ section.settings.ed2_image | image_url: width: 1200 }}"
          alt="{{ section.settings.ed2_image.alt | escape }}" loading="lazy" />
      {%- else -%}
        <div class="vl-tile-placeholder" style="height:100%;"><span>Created Diamonds</span></div>
      {%- endif -%}
    </div>
    <div class="vl-editorial-txt">
      <p class="vl-ed-eyebrow">{{ section.settings.ed2_eyebrow }}</p>
      <h2 class="vl-ed-title">{{ section.settings.ed2_title | newline_to_br }}</h2>
      <p class="vl-ed-body">{{ section.settings.ed2_body }}</p>
      <a class="vl-ed-link" href="{{ section.settings.ed2_url | default: '/collections/lab-grown-diamonds' }}">{{ section.settings.ed2_cta }}</a>
    </div>
  </section>

  {%- comment -%} ── FEATURED PRODUCTS ── {%- endcomment -%}
  {%- assign fp_collection = collections[section.settings.featured_collection] -%}
  {%- if fp_collection != blank and fp_collection.products.size > 0 -%}
  <section class="vl-products">
    <div class="vl-products-header">
      <h2 class="vl-products-title">
        {{ section.settings.products_title | newline_to_br }}
      </h2>
      <a class="vl-products-viewall" href="/collections/{{ fp_collection.handle }}">View all</a>
    </div>
    <div class="vl-product-grid">
      {%- for product in fp_collection.products limit: 4 -%}
      <div class="vl-product-card">
        <a href="{{ product.url }}">
          <div class="vl-product-img-wrap">
            {%- if product.featured_image -%}
              <img class="vl-product-img"
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.featured_image.alt | escape }}"
                loading="lazy" />
            {%- else -%}
              <div class="vl-product-placeholder" style="height:100%;">
                <span>{{ product.title }}</span>
              </div>
            {%- endif -%}
          </div>
          <div class="vl-product-info">
            <p class="vl-product-collection">{{ product.collections.first.title }}</p>
            <p class="vl-product-name">{{ product.title }}</p>
            <p class="vl-product-price">{{ product.price | money }}</p>
          </div>
        </a>
      </div>
      {%- endfor -%}
    </div>
  </section>
  {%- endif -%}

  {%- comment -%} ── ENQUIRE ── {%- endcomment -%}
  <section class="vl-enquire" id="vl-enquire">
    <div class="vl-enquire-vis">
      {%- if section.settings.enquire_image != blank -%}
        <img src="{{ section.settings.enquire_image | image_url: width: 1200 }}"
          alt="" loading="lazy" />
      {%- else -%}
        <div class="vl-tile-placeholder" style="height:100%;"><span>Velonna Atelier</span></div>
      {%- endif -%}
      <div class="vl-enquire-vis-ov"></div>
      <div class="vl-enquire-vis-caption">
        <strong>The Velonna Atelier</strong>
        <p>Contemporary luxury,<br>accessible price points.</p>
      </div>
    </div>
    <div class="vl-enquire-form">
      <p class="vl-enquire-eyebrow">Velonna</p>
      <h2 class="vl-enquire-title">Enquire About<br><em>a Piece</em></h2>
      <p class="vl-enquire-sub">
        Questions about a piece, custom orders, or anything else — we reply within 24 hours.
      </p>
      <form class="vl-form" action="/contact#vl-enquire" method="POST">
        <input type="hidden" name="form_type" value="contact" />
        <input type="hidden" name="utf8" value="✓" />
        <div class="vl-form-row">
          <div class="vl-form-g">
            <label for="vl-fname">First name</label>
            <input id="vl-fname" name="contact[first_name]" type="text" required placeholder="Your name" autocomplete="given-name" />
          </div>
          <div class="vl-form-g">
            <label for="vl-lname">Last name</label>
            <input id="vl-lname" name="contact[last_name]" type="text" required placeholder="Last name" autocomplete="family-name" />
          </div>
        </div>
        <div class="vl-form-g">
          <label for="vl-email">Email address</label>
          <input id="vl-email" name="contact[email]" type="email" required placeholder="you@example.com" autocomplete="email" />
        </div>
        <div class="vl-form-g">
          <label for="vl-phone">Phone / WhatsApp</label>
          <input id="vl-phone" name="contact[phone]" type="tel" placeholder="+91 98000 00000" autocomplete="tel" />
        </div>
        <div class="vl-form-g">
          <label for="vl-interest">I'm interested in</label>
          <select id="vl-interest" name="contact[interest]">
            <option value="">— Select —</option>
            <option>Silver jewellery</option>
            <option>Created diamond pieces</option>
            <option>Occasion wear / statement pieces</option>
            <option>Swarovski crystal designs</option>
            <option>Custom / bespoke order</option>
            <option>Franchise enquiry</option>
          </select>
        </div>
        <div class="vl-form-g">
          <label for="vl-msg">Message <span style="opacity:0.4">(optional)</span></label>
          <textarea id="vl-msg" name="contact[body]" rows="3" placeholder="Tell us more..."></textarea>
        </div>
        <button class="vl-submit" type="submit">Send Enquiry</button>
        <p class="vl-form-note">We reply within 24 hours. Your details stay private.</p>
      </form>
    </div>
  </section>

</div>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />

<script>
(function () {
  // Simple fade-in on scroll for editorial elements
  if (!('IntersectionObserver' in window)) return;

  var targets = document.querySelectorAll(
    '.vl-statement-inner, .vl-ed-eyebrow, .vl-ed-title, .vl-ed-body, .vl-ed-link, ' +
    '.vl-feature-content, .vl-enquire-title, .vl-enquire-sub, ' +
    '.vl-products-header, .vl-product-card'
  );

  targets.forEach(function (el) {
    el.style.opacity = '0';
    el.style.transform = 'translateY(24px)';
    el.style.transition = 'opacity 0.8s ease, transform 0.8s ease';
  });

  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) {
        e.target.style.opacity = '1';
        e.target.style.transform = 'none';
        io.unobserve(e.target);
      }
    });
  }, { rootMargin: '0px 0px -60px 0px', threshold: 0.1 });

  targets.forEach(function (el) { io.observe(el); });

  // Stagger product cards
  document.querySelectorAll('.vl-product-card').forEach(function (card, i) {
    card.style.transitionDelay = (i * 0.08) + 's';
  });
})();
</script>

