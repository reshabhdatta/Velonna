    { "type": "header", "content": "Full-bleed Feature" },
    { "type": "image_picker", "id": "feature_image",   "label": "Background image" },
    { "type": "text",   "id": "feature_eyebrow",  "label": "Eyebrow",  "default": "Created Diamonds · IGI Certified" },
    { "type": "textarea","id": "feature_quote",   "label": "Quote",    "default": "Light, made by science. Set by hand." },
    { "type": "text",   "id": "feature_cta",     "label": "CTA",      "default": "Shop Created Diamonds" },
    { "type": "url",    "id": "feature_cta_url", "label": "CTA URL" },

    { "type": "header", "content": "Editorial — Created Diamonds" },
    { "type": "image_picker", "id": "ed2_image",   "label": "Image" },
    { "type": "text",   "id": "ed2_eyebrow", "label": "Eyebrow",  "default": "Created Diamonds" },
    { "type": "textarea","id": "ed2_title",  "label": "Title",    "default": "For the\n<em>Exceptional</em>\nMoment" },
    { "type": "textarea","id": "ed2_body",   "label": "Body",     "default": "Lab-grown diamonds and Swarovski crystals — physically and chemically identical to mined stones, set into designs inspired by the world's great jewellery houses. Identical light. A fraction of the price." },
    { "type": "text",   "id": "ed2_cta",    "label": "CTA",      "default": "Explore Created Diamonds" },
