    { "type": "textarea","id": "ed1_body",   "label": "Body",     "default": "Sterling silver pieces with a contemporary, luxury-led design language. From delicate everyday wear to bold statement pieces — crafted for the woman who moves between modern and traditional settings." },
    { "type": "text",   "id": "ed1_cta",    "label": "CTA",      "default": "Explore Silver" },
