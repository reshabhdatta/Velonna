{% doc %}
  @prompt
    Create a Shopify section that displays an "Estimated Delivery Time" input UI exactly like this:
    
    Design requirements:
    
    * A heading at the top: **"Estimated Delivery Time"**
    * Below it, a rounded input container with:
    
      * A text input field with placeholder: **"Enter 6 digit pincode"**
      * A button on the right labeled **"Check"**
    * The input and button should appear as one combined rounded box (like a pill shape)
    * The right side (button area) should have a slightly darker pink background
    * The left side (input field) should have a light background
    * Border radius: large (pill style, ~40px or more)
    * Soft border with light pink tone
    * Clean, modern UI spacing similar to Shopify Dawn theme
    
    Functional requirements:
    
    * Accept only 6-digit numeric input
    * On clicking "Check", show a message below:
    
      * If valid: "Delivery available to this location"
      * If invalid: "Please enter a valid 6-digit pincode"
    * Add basic validation using JavaScript
    
    Technical requirements:
    
    * Use Shopify Liquid for section structure
    * Use HTML + CSS (no external libraries)
    * Use vanilla JavaScript for validation
    * Make it responsive (mobile-friendly)
    * Follow clean Shopify section schema so it can be added via theme editor
    
    Styling details:
    
    * Font: system or Shopify default
    * Button hover effect (slightly darker shade)
    * Smooth transitions (0.2s ease)
    * Proper padding inside input (12–16px)
    
    Output:
    
    * Provide full Shopify section code (Liquid + HTML + CSS + JS in one file)
    * Ensure it's copy-paste ready
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-delivery-checker-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.container_padding }}px;
  }

  .ai-delivery-checker__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
    margin: 0 0 16px 0;
    color: {{ block.settings.heading_color }};
  }

  .ai-delivery-checker__form-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    align-items: stretch;
    border: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.input_bg_color }};
    transition: all 0.2s ease;
  }

  .ai-delivery-checker__input-{{ ai_gen_id }} {
    flex: 1;
    padding: {{ block.settings.input_padding }}px;
    border: none;
    background-color: transparent;
    font-size: {{ block.settings.input_font_size }}px;
    color: {{ block.settings.input_text_color }};
    outline: none;
  }

  .ai-delivery-checker__input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.placeholder_color }};
    opacity: 0.7;
  }

  .ai-delivery-checker__button-{{ ai_gen_id }} {
    padding: {{ block.settings.input_padding }}px {{ block.settings.button_padding }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease;
    white-space: nowrap;
  }

  .ai-delivery-checker__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
  }

  .ai-delivery-checker__message-{{ ai_gen_id }} {
    margin-top: 12px;
    padding: 12px 16px;
    border-radius: {{ block.settings.message_border_radius }}px;
    font-size: {{ block.settings.message_font_size }}px;
    display: none;
    transition: all 0.2s ease;
  }

  .ai-delivery-checker__message-{{ ai_gen_id }}.success {
    display: block;
    background-color: {{ block.settings.success_bg_color }};
    color: {{ block.settings.success_text_color }};
  }

  .ai-delivery-checker__message-{{ ai_gen_id }}.error {
    display: block;
    background-color: {{ block.settings.error_bg_color }};
    color: {{ block.settings.error_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-delivery-checker-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-delivery-checker__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.9);
    }

    .ai-delivery-checker__input-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.input_font_size }}px * 0.95);
    }

    .ai-delivery-checker__button-{{ ai_gen_id }} {
      padding: {{ block.settings.input_padding }}px {{ block.settings.button_padding | times: 0.8 }}px;
      font-size: calc({{ block.settings.button_font_size }}px * 0.95);
    }
  }
{% endstyle %}

<delivery-checker-{{ ai_gen_id }} class="ai-delivery-checker-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <h3 class="ai-delivery-checker__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h3>
  
  <div class="ai-delivery-checker__form-{{ ai_gen_id }}">
    <input
      type="text"
      class="ai-delivery-checker__input-{{ ai_gen_id }}"
      placeholder="{{ block.settings.placeholder }}"
      maxlength="6"
      inputmode="numeric"
      aria-label="Enter pincode"
      data-pincode-input
    >
    <button
      type="button"
      class="ai-delivery-checker__button-{{ ai_gen_id }}"
      data-check-button
    >
      {{ block.settings.button_text }}
    </button>
  </div>

  <div class="ai-delivery-checker__message-{{ ai_gen_id }}" data-message></div>
</delivery-checker-{{ ai_gen_id }}>

<script>
  (function() {
    class DeliveryChecker{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.input = this.querySelector('[data-pincode-input]');
        this.button = this.querySelector('[data-check-button]');
        this.message = this.querySelector('[data-message]');
        
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.input.addEventListener('input', (e) => {
          e.target.value = e.target.value.replace(/[^0-9]/g, '');
        });

        this.input.addEventListener('keypress', (e) => {
          if (e.key === 'Enter') {
            e.preventDefault();
            this.checkPincode();
          }
        });

        this.button.addEventListener('click', () => {
          this.checkPincode();
        });
      }

      checkPincode() {
        const pincode = this.input.value.trim();
        
        this.message.classList.remove('success', 'error');
        
        if (pincode.length === 6 && /^\d{6}$/.test(pincode)) {
          this.message.textContent = '{{ block.settings.success_message }}';
          this.message.classList.add('success');
        } else {
          this.message.textContent = '{{ block.settings.error_message }}';
          this.message.classList.add('error');
        }
      }
    }

    customElements.define('delivery-checker-{{ ai_gen_id }}', DeliveryChecker{{ ai_gen_id }});
  })();
</script>

